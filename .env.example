# -------------------------------------------------
# ENLIL -- Variables de entorno
# Copia este fichero como .env y rellena los valores
# -------------------------------------------------

# -- LLM (obligatorio) ----------------------------
# Clave de OpenRouter -- obtén la tuya en openrouter.ai
OPENROUTER_API_KEY=sk-or-...

# Clave de Anthropic (opcional -- solo si no usas OpenRouter para Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# -- Base de datos --------------------------------
# Ruta al fichero SQLite. Con docker-compose usa /app/data/enlil.db
ENLIL_DB=./data/enlil.db

# -- Criptografia post-cuantica (ML-DSA-87) -------
# Ruta a la clave PQ. Se genera automaticamente si no existe.
ENLIL_PQ_KEYPATH=./data/enlil_pq.key

# -- Administracion --------------------------------
# Clave maestra para endpoints de admin (/admin/*)
# Genera una segura con: python3 -c 'import secrets; print(secrets.token_hex(32))'
ENLIL_MASTER_KEY=cambia_esto_por_una_clave_segura

# -- URLs (opcional) -------------------------------
# URL publica de tu instancia (aparece en decretos exportados)
ENLIL_BASE_URL=http://localhost:8002

# -- Qdrant (opcional) ----------------------------
# Si usas Qdrant externo. Con docker-compose apunta a http://qdrant:6333
QDRANT_URL=http://localhost:6333

# -- Email (opcional) -----------------------------
# Solo si quieres envio de decretos por email
# GMAIL_USER=tu@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
